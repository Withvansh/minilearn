{
  "name": "minilearn-backend",
  "version": "1.0.0",
  "description": "ESM Backend API for MiniLearn production-ready micro-learning platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
